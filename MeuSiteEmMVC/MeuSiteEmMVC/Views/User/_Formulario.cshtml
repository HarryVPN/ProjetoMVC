@model UserModel

<div class="form-group">
    <label for="nome">Nome</label>
    <input type="text" required asp-for="Nome" class="form-control" placeholder="Digite o Nome">
</div>

<div class="form-group">
    <label for="nome">Cargo</label>
    <input type="text" required asp-for="Cargo" class="form-control" placeholder="Digite o Nome">
    @Html.ValidationMessageFor(x => x.Cargo)
</div>

<div class="form-group">
    <label for="email">Email</label>
    <input type="text" required asp-for="Email" class="form-control" placeholder="Digite o Email">
    @Html.ValidationMessageFor(x => x.Email)    
</div>
<br />